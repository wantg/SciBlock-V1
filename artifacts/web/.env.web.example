# =============================================================================
# SciBlock Frontend (artifacts/web) — Environment Variables
# =============================================================================
# 
# 使用说明：
# 1. 复制此文件为 .env: cp .env.web.example .env
# 2. 根据需要修改配置（如启用 VITE_DEV_MODE）
# 3. .env 文件不会被提交到 git，请放心修改本地配置
# =============================================================================
# Vite reads variables prefixed with VITE_ at build time and makes them
# available as import.meta.env.VITE_*.
# Non-prefixed variables are only available in vite.config.ts (server-side).
# =============================================================================

# ---------------------------------------------------------------------------
# Server-side (vite.config.ts only — NOT available in browser code)
# ---------------------------------------------------------------------------

# Port for the Vite dev server.
# Replit injects this automatically.  Set manually when running locally.
# Required: yes
PORT=22333

# Base URL path for the app.  Use "/" when hosting at the domain root.
# Replit injects this automatically.  Defaults to "/" if not set.
# Required: no (defaults to "/")
BASE_PATH=/

# ---------------------------------------------------------------------------
# Build-time browser variables (VITE_ prefix — available in browser code)
# ---------------------------------------------------------------------------

# Currently all API calls use relative paths via apiFetch(), so no explicit
# API URL variable is needed in the browser bundle.

# Future: if you ever need to point to a different API host at build time,
# add it here:
# VITE_API_BASE_URL=https://api.sciblock.example.com

# ---------------------------------------------------------------------------
# Development mode (frontend only)
# ---------------------------------------------------------------------------

# Enable dev mode to show quick login accounts selector on login page.
# WARNING: Keep this unset or false in production environments.
# VITE_DEV_MODE=true
