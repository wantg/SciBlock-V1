# 构建阶段
FROM node:20-slim AS builder

WORKDIR /app

# 安装 pnpm
RUN npm install -g pnpm

# 防止 rollup 原生模块错误
ENV ROLLUP_NATIVE=0

# 构建参数：VITE_DEV_MODE（默认 false，仅在需要时通过 --build-arg 传入）
ARG VITE_DEV_MODE=false
ENV VITE_DEV_MODE=${VITE_DEV_MODE}

# 复制工作区配置文件
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

# 安装所有依赖（包括 workspace）
RUN pnpm install --frozen-lockfile

# 复制源代码
COPY artifacts/web ./artifacts/web
COPY lib ./lib

# 进入 web 目录构建
WORKDIR /app/artifacts/web
# 安装该工作区的依赖（包括 devDependencies）
RUN pnpm install
# 禁用 rollup 原生模块（避免 Alpine 兼容性问题）
ENV ROLLUP_DISABLE_NATIVE=1
# 设置构建所需的 PORT（vite.config.ts 需要）
ENV PORT=3000
RUN echo '{"compilerOptions": {}}' > ../../tsconfig.base.json
RUN pnpm run build

# 运行时阶段 - 使用 nginx
FROM nginx:alpine

# 复制 nginx 配置
COPY artifacts/web/nginx.conf /etc/nginx/nginx.conf

# 从构建阶段复制构建产物到 nginx 默认目录
COPY --from=builder /app/artifacts/web/dist/public /usr/share/nginx/html

# 暴露 80 端口
EXPOSE 80

# 启动 nginx
CMD ["nginx", "-g", "daemon off;"]
