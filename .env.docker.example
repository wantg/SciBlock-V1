# SciBlock Docker 开发环境变量示例
# 复制此文件为 .env.docker 并根据需要修改

# =============================================================================
# 安全密钥（必须设置）
# =============================================================================

# JWT 签名密钥（Go API 和 Express API 必须一致）
# 生成命令：openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32

# Express API 管理员密钥（保护 /api/admin/users 端点）
# 生成命令：openssl rand -hex 16
ADMIN_SECRET=sciblock-admin-dev

# =============================================================================
# 环境模式
# =============================================================================

# Go API 环境（development / production）
ENV=development

# Node 环境（development / production）
NODE_ENV=development

# =============================================================================
# 数据库与缓存（由 docker-compose 自动配置，一般无需修改）
# =============================================================================

# PostgreSQL 连接字符串（容器内使用）
DATABASE_URL=postgresql://sciblock:sciblock_password@postgres:5432/sciblock

# Redis 连接字符串（容器内使用）
REDIS_URL=redis://redis:6379

# =============================================================================
# Go API 配置
# =============================================================================

# 端口（容器内）
PORT=8082

# 自动迁移（开发环境建议开启）
AUTO_MIGRATE=true

# JWT 有效期（小时）
JWT_EXPIRY_HOURS=168

# bcrypt 计算成本
BCRYPT_COST=12

# CORS 允许的来源（逗号分隔）
CORS_ORIGINS=http://localhost:80

# =============================================================================
# Express API 配置
# =============================================================================

# 端口（容器内）
PORT=8080

# Go API 内部地址（容器间通信）
GO_API_URL=http://go-api:8082

# AI 提供商（qianwen / openai / local）
AI_PROVIDER=qianwen

# 阿里云 DashScope API 密钥（AI_PROVIDER=qianwen 时需填写）
DASHSCOPE_API_KEY=

# OpenAI API 密钥（AI_PROVIDER=openai 时需填写）
OPENAI_API_KEY=

# =============================================================================
# 前端配置
# =============================================================================

# 端口（容器内）
PORT=22333

# 应用基础路径（一般保持 /）
BASE_PATH=/

# 构建时使用的 API 基础地址（留空则使用相对路径）
VITE_API_BASE_URL=

# 开发模式：启用前端辅助登录框（默认关闭，需要手动开启）
# 警告：生产环境必须保持关闭或未设置
# VITE_DEV_MODE=true

# =============================================================================
# 迁移服务配置
# =============================================================================

# 迁移时使用的数据库连接（同 DATABASE_URL）
MIGRATION_DATABASE_URL=${DATABASE_URL}

# =============================================================================
# 提示
# =============================================================================

# 注意：Docker Compose 会自动注入部分变量（如 DATABASE_URL），
# 但 JWT_SECRET 和 ADMIN_SECRET 必须手动设置并保持一致。