# =============================================================================
# SciBlock — Root Environment Variables Reference
# =============================================================================
# Copy this file and fill in real values.  Never commit real secrets.
#
# Each service also has its own .env.*.example file:
#   artifacts/web/.env.web.example
#   artifacts/api-server/.env.server.example
#   artifacts/go-api/.env.go.example
#
# When running locally without Replit, set these in your shell or a .env file
# and source it before starting the services.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (shared by Express + Go)
# ---------------------------------------------------------------------------
# Required by: Express (Drizzle ORM), Go API (pgx)
DATABASE_URL=postgresql://postgres:081e547e37a0f121dbed1c930171365d@localhost:5432/sciblock_v1
EXTERNAL_DATABASE_URL=postgresql://postgres:081e547e37a0f121dbed1c930171365d@localhost:5432/sciblock_v1

# ---------------------------------------------------------------------------
# Shared secrets — MUST be identical in Express API and Go API
# ---------------------------------------------------------------------------
# The Go API issues JWTs and Express validates them.  Both services must use
# the same JWT_SECRET and algorithm (HS256) or authentication will break.
#
# !! PRODUCTION REQUIRED: replace the placeholder below before deploying !!
# Generate a secure key with:   openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32

# JWT token expiry in hours (default: 168 = 7 days).
JWT_EXPIRY_HOURS=168

# ---------------------------------------------------------------------------
# Express API Server (artifacts/api-server)
# ---------------------------------------------------------------------------
# Port the Express server listens on.
# Replit sets this automatically; set manually when self-hosting.
EXPRESS_PORT=8080

# Secret used to guard the admin user-creation endpoint.
# POST /api/admin/users requires: Authorization: Bearer <ADMIN_SECRET>
ADMIN_SECRET=sciblock-admin-dev

# AI provider selection. Options: qianwen (default) | openai | local
AI_PROVIDER=qianwen

# Aliyun DashScope key (required when AI_PROVIDER=qianwen)
DASHSCOPE_API_KEY=

# OpenAI key (required when AI_PROVIDER=openai)
OPENAI_API_KEY=

# Internal URL where Express forwards requests to the Go backend.
# Set after the Go backend is running.
GO_API_URL=http://localhost:8082

# ---------------------------------------------------------------------------
# Go API Server (artifacts/go-api)
# ---------------------------------------------------------------------------
# Port the Go server listens on (internal; not exposed to Replit routing).
GO_PORT=8082

# bcrypt cost factor (10–14 recommended; higher = slower + more secure).
BCRYPT_COST=12

# Allowed CORS origins for the Go API (comma-separated).
# Empty → permissive mode (all origins allowed, suitable for development).
# Production: set this to the exact origin(s) of the frontend, e.g.:
#   CORS_ORIGINS=https://sciblock.example.com
CORS_ORIGINS=

# ---------------------------------------------------------------------------
# Frontend / Vite (artifacts/web)
# ---------------------------------------------------------------------------
# Port the Vite dev server listens on.
WEB_PORT=22333

# Base URL path for the frontend.  Use "/" when hosting at the domain root.
# Replit sets this automatically; set to "/" when self-hosting.
BASE_PATH=/

# ---------------------------------------------------------------------------
# Object Storage — RESERVED for Phase 2 (attachments)
# ---------------------------------------------------------------------------
# Uncomment and fill in when implementing file upload.

# STORAGE_PROVIDER=s3          # s3 | minio | replit
# STORAGE_BUCKET=sciblock-files
# STORAGE_ENDPOINT=            # custom endpoint for MinIO / S3-compatible
# STORAGE_REGION=ap-northeast-1
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Environment / Runtime
# ---------------------------------------------------------------------------
NODE_ENV=development
