{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0 <21 || >=22.12.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "dev": "sh scripts/dev.sh",
    "dev:web": "sh scripts/dev.sh web",
    "dev:api": "sh scripts/dev.sh api",
    "dev:go": "sh scripts/dev.sh go",
    "dev:go:win": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/dev-go.ps1",
    "dev:go:win:migrate": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/dev-go.ps1 -AutoMigrate",
    "build": "sh scripts/build.sh",
    "build:web": "sh scripts/build.sh web",
    "build:api": "sh scripts/build.sh api",
    "build:go": "sh scripts/build.sh go",
    "migrate": "bash scripts/migrate.sh",
    "migrate:drizzle": "bash scripts/migrate.sh drizzle",
    "migrate:goose": "bash scripts/migrate.sh goose",
    "deploy:dev": "bash cmd/deploy.dev.sh",
    "deploy:prod": "bash cmd/deploy.production.sh",
    "deploy:down:dev": "bash cmd/deploy.stop.sh dev",
    "deploy:down:prod": "bash cmd/deploy.stop.sh prod",
    "deploy:health:dev": "bash cmd/deploy.health.sh dev",
    "deploy:health:prod": "bash cmd/deploy.health.sh prod",
    "deploy:logs:dev": "bash cmd/deploy.logs.sh dev",
    "deploy:logs:prod": "bash cmd/deploy.logs.sh prod",
    "deploy:migrate": "bash cmd/migrate.sh",
    "deploy:dev:win": "pwsh -NoProfile -ExecutionPolicy Bypass -File cmd/deploy.dev.ps1",
    "deploy:prod:win": "pwsh -NoProfile -ExecutionPolicy Bypass -File cmd/deploy.production.ps1",
    "deploy:down:win": "pwsh -NoProfile -ExecutionPolicy Bypass -File cmd/deploy.stop.ps1",
    "deploy:health:win": "pwsh -NoProfile -ExecutionPolicy Bypass -File cmd/deploy.health.ps1",
    "deploy:logs:win": "pwsh -NoProfile -ExecutionPolicy Bypass -File cmd/deploy.logs.ps1",
    "deploy:migrate:win": "pwsh -NoProfile -ExecutionPolicy Bypass -File cmd/migrate.ps1",
    "db:generate": "pnpm --filter @workspace/db run generate",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}