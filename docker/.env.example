# Development environment template (used by docker-compose.yml)
# Copy to docker/.env.dev and adjust if needed.

POSTGRES_DB=sciblock
POSTGRES_USER=sciblock
POSTGRES_PASSWORD=sciblock
POSTGRES_PORT=5432

FRONTEND_PORT=22333
BACKEND_PORT=8080
GO_PORT=8082

JWT_SECRET=sciblock-dev-jwt-change-me
ADMIN_SECRET=sciblock-dev-admin-change-me
CORS_ORIGINS=http://localhost:22333

ENV=development
NODE_ENV=production
AUTO_MIGRATE=true
RUN_MIGRATIONS=true
RUN_BOOTSTRAP_SQL=true
RUN_SEED=true
